# Sprite Creator — environment variables
# Copy this file to .env.local and fill in real values.
# In Vercel, set these in Project Settings → Environment Variables for all environments.

# Default image-generation provider id. One of: pollinations, huggingface, gemini.
# If unset, the server auto-picks the first available in this priority:
#   huggingface (if HF_TOKEN set) -> pollinations (always) -> gemini (if billing on)
IMAGE_PROVIDER=

# HuggingFace free token (recommended). Grab one for free at:
#   https://huggingface.co/settings/tokens  (Read scope is sufficient)
# Without this, the app still works using Pollinations (no auth, no signup).
HF_TOKEN=

# Optional override for the HuggingFace model id. Default: black-forest-labs/FLUX.1-schnell.
HUGGINGFACE_MODEL=

# Gemini configuration (paid only as of May 2026 — Google removed the free image-gen tier
# for new accounts in Dec 2025). Leave both blank to disable the Gemini provider.
# When you do enable Google Cloud billing, set both and the provider activates automatically.
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Upstash Redis (rate-limiter state). These are written automatically by
# `vercel integration add upstash/upstash-kv` and synced via `vercel env pull`.
# Vercel's Upstash Marketplace integration provisions them under the KV_ prefix.
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=
REDIS_URL=
