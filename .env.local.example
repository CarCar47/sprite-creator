# Sprite Creator — environment variables
# Copy this file to .env.local and fill in real values.
# In Vercel, set these in Project Settings → Environment Variables for all environments.

# Google Gemini image-generation model.
# Default uses Nano Banana 2 (current as of May 2026). Override to gemini-3-pro-image-preview
# for quality A/B testing. See docs/Phase-0-Amendments.md for the full deprecation timeline.
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview

# Gemini API key. Obtain at https://aistudio.google.com/apikey.
# Never commit this value.
GEMINI_API_KEY=

# Upstash Redis (rate-limiter state). These are written automatically by
# `vercel integration add upstash` and synced via `vercel env pull`.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
