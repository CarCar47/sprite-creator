# Sprite Creator — environment variables
# Copy this file to .env.local and fill in real values.
# In Vercel, set these in Project Settings → Environment Variables for all environments.

# Google Gemini image-generation model.
# Default uses gemini-2.5-flash-image — the only image-gen model currently on the
# Gemini API FREE tier (~500 req/day). It is scheduled for shutdown 10/02/2026; at
# that point switch to gemini-3.1-flash-image-preview (paid only, ~$0.067/img) or
# whatever Google promotes as the next free-tier image model.
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image

# Gemini API key. Obtain at https://aistudio.google.com/apikey.
# Never commit this value.
GEMINI_API_KEY=

# Upstash Redis (rate-limiter state). These are written automatically by
# `vercel integration add upstash/upstash-kv` and synced via `vercel env pull`.
# Vercel's Upstash Marketplace integration provisions them under the KV_ prefix.
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
KV_URL=
REDIS_URL=
